<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Grimoire.Desktop.ViewModels"
             xmlns:svc="using:Grimoire.Desktop.Services"
             x:Class="Grimoire.Desktop.Views.DownloadsView"
             x:DataType="vm:DownloadsViewModel">

    <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="Downloads" FontSize="26" FontWeight="Bold"
                   Foreground="#d4af37" Margin="0,0,0,18"
                   FontFamily="Palatino Linotype, Georgia, serif" LetterSpacing="1" />

        <TextBlock DockPanel.Dock="Top" Text="No active downloads."
                   Foreground="#5c564e" FontStyle="Italic" Margin="0,20"
                   HorizontalAlignment="Center"
                   IsVisible="{Binding !Downloads.Count}" />

        <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Downloads}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="svc:DownloadItem">
                        <Border Background="#1a192a" CornerRadius="8" Padding="16" Margin="0,0,0,10"
                                BorderBrush="#2a2840" BorderThickness="1">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Right" VerticalAlignment="Center" Margin="16,0,0,0">
                                    <Button Content="Cancel"
                                            Command="{Binding $parent[ItemsControl].DataContext.CancelDownloadCommand}"
                                            CommandParameter="{Binding}"
                                            Classes="outline-btn" Padding="10,5" FontSize="11" />
                                </StackPanel>

                                <StackPanel Spacing="8">
                                    <!-- Name + Status -->
                                    <DockPanel>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#e8e8ef"
                                                   FontSize="14" TextTrimming="CharacterEllipsis" />
                                    </DockPanel>

                                    <!-- Progress bar -->
                                    <Grid>
                                        <ProgressBar Minimum="0" Maximum="100"
                                                     Value="{Binding ProgressPercent}"
                                                     Height="6" Foreground="#d4af37" Background="#100f1b"
                                                     CornerRadius="3" />
                                    </Grid>

                                    <!-- Stats row -->
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Left" Foreground="#8a8078" FontSize="12"
                                                   Text="{Binding StatusText}" />
                                        <TextBlock DockPanel.Dock="Right" Foreground="#d4af37" FontSize="12"
                                                   HorizontalAlignment="Right">
                                            <Run Text="{Binding ProgressPercent, StringFormat={}{0:F1}%}" />
                                            <Run Text=" — " Foreground="#5c564e" />
                                            <Run Text="{Binding ProgressText}" Foreground="#8a8078" />
                                        </TextBlock>
                                    </DockPanel>

                                    <!-- Error -->
                                    <TextBlock Text="{Binding Error}" Foreground="#e74c3c" FontSize="12"
                                               TextWrapping="Wrap"
                                               IsVisible="{Binding Error, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
