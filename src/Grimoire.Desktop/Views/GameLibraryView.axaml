<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Grimoire.Desktop.ViewModels"
             xmlns:conv="using:Grimoire.Desktop.Converters"
             x:Class="Grimoire.Desktop.Views.GameLibraryView"
             x:DataType="vm:GameLibraryViewModel">

    <DockPanel>
        <!-- Header -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,18">
            <TextBlock Text="The Tome" FontSize="26" FontWeight="Bold"
                       Foreground="#d4af37" VerticalAlignment="Center"
                       FontFamily="Palatino Linotype, Georgia, serif" LetterSpacing="1" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <TextBox Text="{Binding SearchText}" Watermark="Search the archives..."
                         Width="260" Classes="search-input" />
                <Button Content="Search" Command="{Binding LoadGamesCommand}" Classes="accent-btn" />
            </StackPanel>
        </DockPanel>

        <!-- Platform Filter -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="0,0,0,18">
            <Button Content="All" Command="{Binding FilterPlatformCommand}" CommandParameter="{x:Null}" Classes="filter-btn" />
            <Button Content="Switch" Command="{Binding FilterPlatformCommand}" CommandParameter="NintendoSwitch" Classes="filter-btn" />
            <Button Content="DS" Command="{Binding FilterPlatformCommand}" CommandParameter="NintendoDS" Classes="filter-btn" />
            <Button Content="3DS" Command="{Binding FilterPlatformCommand}" CommandParameter="Nintendo3DS" Classes="filter-btn" />
            <Button Content="GB/GBA" Command="{Binding FilterPlatformCommand}" CommandParameter="GameBoy" Classes="filter-btn" />
        </StackPanel>

        <!-- Error Message -->
        <Border DockPanel.Dock="Top" IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                Background="#2a0a0a" CornerRadius="4" Padding="14" Margin="0,0,0,14"
                BorderBrush="#c0392b50" BorderThickness="1">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#e74c3c" TextWrapping="Wrap" FontStyle="Italic" />
        </Border>

        <!-- Loading -->
        <TextBlock DockPanel.Dock="Top" Text="Consulting the archives..." Foreground="#5c564e"
                   IsVisible="{Binding IsLoading}" Margin="0,30" HorizontalAlignment="Center"
                   FontStyle="Italic" FontSize="15" />

        <!-- Game Detail Overlay -->
        <Border DockPanel.Dock="Top" IsVisible="{Binding ShowDetail}"
                Background="#1a192a" CornerRadius="8" Padding="24" Margin="0,0,0,18"
                BorderBrush="#2a2840" BorderThickness="1">
            <DockPanel>
                <Button DockPanel.Dock="Top" Content="Back to Library"
                        Command="{Binding CloseDetailCommand}"
                        Classes="outline-btn" HorizontalAlignment="Left" Margin="0,0,0,16"
                        FontSize="12" Padding="12,6" />
                <StackPanel IsVisible="{Binding GameDetail, Converter={x:Static ObjectConverters.IsNotNull}}" Spacing="10">
                    <TextBlock Text="{Binding GameDetail.Title}" FontSize="24" FontWeight="Bold"
                               Foreground="#d4af37" FontFamily="Palatino Linotype, Georgia, serif" />
                    <TextBlock Text="{Binding GameDetail.Description}" Foreground="#8a8078"
                               TextWrapping="Wrap" FontStyle="Italic" FontSize="14" LineHeight="22" />
                    <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,4,0,0">
                        <TextBlock Foreground="#5c564e" FontSize="13">
                            <Run Text="Platform: " /><Run Text="{Binding GameDetail.Platform, Converter={x:Static conv:PlatformNameConverter.Instance}}" Foreground="#d4af37" />
                        </TextBlock>
                        <TextBlock Foreground="#5c564e" FontSize="13">
                            <Run Text="DLC: " /><Run Text="{Binding GameDetail.Dlcs.Count}" Foreground="#d4af37" />
                        </TextBlock>
                        <TextBlock Foreground="#5c564e" FontSize="13">
                            <Run Text="Updates: " /><Run Text="{Binding GameDetail.Updates.Count}" Foreground="#d4af37" />
                        </TextBlock>
                    </StackPanel>

                    <!-- Play Button -->
                    <StackPanel Margin="0,12,0,0" Spacing="8">
                        <Button Command="{Binding LaunchGameCommand}"
                                IsEnabled="{Binding !IsLaunching}"
                                Classes="play-btn">
                            <Panel>
                                <TextBlock Text="INVOKE" IsVisible="{Binding !IsLaunching}" LetterSpacing="4" />
                                <TextBlock Text="SUMMONING..." IsVisible="{Binding IsLaunching}" LetterSpacing="2" />
                            </Panel>
                        </Button>
                    </StackPanel>

                    <!-- Launch Progress -->
                    <StackPanel Spacing="6" IsVisible="{Binding ShowLaunchProgress}" Margin="0,4,0,0">
                        <ProgressBar Minimum="0" Maximum="100"
                                     Value="{Binding LaunchProgress}"
                                     Height="6" Foreground="#d4af37" Background="#100f1b"
                                     CornerRadius="3" />
                    </StackPanel>

                    <!-- Launch Status -->
                    <TextBlock Text="{Binding LaunchStatus}" Foreground="#a68a2a" FontSize="13"
                               TextWrapping="Wrap" FontStyle="Italic"
                               IsVisible="{Binding LaunchStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Game Grid -->
        <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Games}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Classes="game-card-btn" Margin="6"
                                Command="{Binding $parent[ItemsControl].DataContext.ViewGameDetailCommand}"
                                CommandParameter="{Binding}">
                            <Border Width="190" CornerRadius="6" ClipToBounds="True"
                                    Background="#1a192a" BorderBrush="#2a2840" BorderThickness="1">
                                <StackPanel>
                                    <Border Height="140" Background="#100f1b" ClipToBounds="True">
                                        <Panel>
                                            <Image Source="{Binding CoverImageUrl, Converter={x:Static conv:CoverUrlConverter.Instance}}"
                                                   Stretch="UniformToFill"
                                                   IsVisible="{Binding CoverImageUrl, Converter={x:Static conv:NotNullOrEmptyConverter.Instance}}" />
                                            <TextBlock Text="{Binding Title[0]}" FontSize="44" FontWeight="Bold"
                                                       Foreground="#a68a2a" Opacity="0.3"
                                                       FontFamily="Palatino Linotype, Georgia, serif"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       IsVisible="{Binding CoverImageUrl, Converter={x:Static conv:IsNullOrEmptyConverter.Instance}}" />
                                        </Panel>
                                    </Border>
                                    <StackPanel Margin="10,8,10,10">
                                        <TextBlock Text="{Binding Title}" FontSize="12.5" FontWeight="SemiBold"
                                                   Foreground="#d8d0c4" TextTrimming="CharacterEllipsis" MaxLines="1" />
                                        <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,5,0,0">
                                            <Border CornerRadius="2" Padding="5,1"
                                                    Background="{Binding Platform, Converter={x:Static conv:PlatformBgConverter.Instance}}"
                                                    BorderBrush="{Binding Platform, Converter={x:Static conv:PlatformBorderConverter.Instance}}"
                                                    BorderThickness="1">
                                                <TextBlock Text="{Binding Platform, Converter={x:Static conv:PlatformNameConverter.Instance}}"
                                                           FontSize="10"
                                                           Foreground="{Binding Platform, Converter={x:Static conv:PlatformColorConverter.Instance}}" />
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
