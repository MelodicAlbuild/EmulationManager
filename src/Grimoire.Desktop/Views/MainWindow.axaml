<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Grimoire.Desktop.ViewModels"
        xmlns:views="using:Grimoire.Desktop.Views"
        x:Class="Grimoire.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding Title}"
        Width="1200" Height="800"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#08070c">

    <Window.Styles>
        <StyleInclude Source="/Assets/Styles.axaml" />
    </Window.Styles>

    <Grid ColumnDefinitions="240,*">
        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#0e0d15" BorderBrush="#2a2840" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- App Title -->
                <Border DockPanel.Dock="Top" Padding="24,24,24,32">
                    <TextBlock Text="Grimoire"
                               FontSize="22" FontWeight="Bold" Foreground="#d4af37"
                               FontFamily="Palatino Linotype, Georgia, serif"
                               LetterSpacing="3" />
                </Border>

                <!-- Nav Items -->
                <StackPanel Spacing="2" Margin="10,0">
                    <Button Command="{Binding NavigateToLibraryCommand}"
                            Classes="nav-btn" Classes.active="{Binding SelectedNavIndex, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=0}">
                        The Tome
                    </Button>
                    <Button Command="{Binding NavigateToDownloadsCommand}"
                            Classes="nav-btn" Classes.active="{Binding SelectedNavIndex, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=1}">
                        Downloads
                    </Button>
                    <Button Command="{Binding NavigateToSettingsCommand}"
                            Classes="nav-btn" Classes.active="{Binding SelectedNavIndex, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=2}">
                        Settings
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Content Area -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentPage}" Margin="28,24">
            <ContentControl.DataTemplates>
                <DataTemplate DataType="vm:GameLibraryViewModel">
                    <views:GameLibraryView />
                </DataTemplate>
                <DataTemplate DataType="vm:DownloadsViewModel">
                    <views:DownloadsView />
                </DataTemplate>
                <DataTemplate DataType="vm:SettingsViewModel">
                    <views:SettingsView />
                </DataTemplate>
            </ContentControl.DataTemplates>
        </ContentControl>
    </Grid>
</Window>
